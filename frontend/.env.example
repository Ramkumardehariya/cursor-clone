# API Configuration
VITE_API_URL=http://localhost:5000/api

# App Configuration
VITE_APP_NAME=Cursor Clone
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=AI-powered code editor

# Development Configuration
VITE_DEV_MODE=true
VITE_DEBUG=false

# WebSocket Configuration
VITE_WS_URL=ws://localhost:5000

# File Upload Configuration
VITE_MAX_FILE_SIZE=10485760
VITE_ALLOWED_FILE_TYPES=.js,.jsx,.ts,.tsx,.html,.css,.scss,.sass,.less,.json,.xml,.yaml,.yml,.md,.txt,.log,.csv,.py,.java,.cpp,.c,.h,.hpp,.cs,.php,.rb,.go,.rs,.swift,.kt,.scala,.r,.sql,.sh,.bash,.zsh,.fish,.ps1,.dockerfile,.graphql,.gql,.lua,.pl

# Editor Configuration
VITE_DEFAULT_THEME=vs-dark
VITE_DEFAULT_FONT_SIZE=14
VITE_DEFAULT_TAB_SIZE=4
VITE_ENABLE_WORD_WRAP=true
VITE_ENABLE_MINIMAP=true

# AI Configuration
VITE_AI_ENABLED=true
VITE_AI_MODEL=meta-llama/llama-3.3-70b-instruct:free
VITE_AI_MAX_TOKENS=4096

# Terminal Configuration
VITE_TERMINAL_ENABLED=true
VITE_TERMINAL_SHELL=bash

# Performance Configuration
VITE_ENABLE_CODE_SPLITTING=true
VITE_ENABLE_LAZY_LOADING=true
